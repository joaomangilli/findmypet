# ── Domínio ────────────────────────────────────────────────────────────────────
DOMAIN=findmypet.app
CADDY_EMAIL=seu@email.com

# ── Banco de dados ─────────────────────────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=troque-por-senha-segura

# ── Rails ──────────────────────────────────────────────────────────────────────
# Gerar com: openssl rand -hex 64
RAILS_MASTER_KEY=
DEVISE_JWT_SECRET_KEY=

# ── Frontend ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.findmypet.app
NEXT_PUBLIC_APP_URL=https://findmypet.app

# ── CORS (origens permitidas na API) ───────────────────────────────────────────
CORS_ORIGINS=https://findmypet.app

# ── WhatsApp (Evolution API) ───────────────────────────────────────────────────
# Gerar com: openssl rand -hex 32
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=findmypet

# ── Object Storage (fotos dos pets) ───────────────────────────────────────────
# Opção A — AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET=findmypet-uploads
AWS_ENDPOINT=

# Opção B — Cloudflare R2 (sem custo de egress)
# AWS_ACCESS_KEY_ID=<R2 token ID>
# AWS_SECRET_ACCESS_KEY=<R2 token secret>
# AWS_REGION=auto
# AWS_BUCKET=findmypet-uploads
# AWS_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
